# ─── App ──────────────────────────────────────────────────────────────────────
# Running multiple projects? Give each one a unique port pair:
#   1. package.json "dev" script  →  next dev --turbo --port 3001
#   2. docker-compose.yml ports  →  '5433:5432'
#   3. Update the three values below (APP_URL, DATABASE_URL, BETTER_AUTH_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3005
# Set to true to enable demo mode (mock emails as toasts, demo user auto-seeded, dev panel)
DEMO_MODE=false

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (Docker):   postgresql://postgres:postgres@localhost:5432/appforge
# Neon:             postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# Supabase:         postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/appforge

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3005

# ─── Auth (Supabase Auth) — alternative to Better Auth ───────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Payments (Paddle) — alternative to Stripe ───────────────────────────────
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── File Storage (Uploadthing) ───────────────────────────────────────────────
# UPLOADTHING_TOKEN=

# ─── File Storage (AWS S3) — alternative to Uploadthing ─────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
